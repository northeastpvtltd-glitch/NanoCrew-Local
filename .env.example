# ============================================================
# NanoCrew-Local — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---- Telegram Bot ----
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Comma-separated Telegram usernames authorized to use this bot.
# Do NOT include the @ symbol.  Example: alice,bob,charlie
ALLOWED_USERNAMES=your_username_here

# ---- Ollama (Local LLM) ----
# Base URL of your running Ollama instance.
OLLAMA_BASE_URL=http://localhost:11434

# Default model for all agents. Override per-agent in crew YAML files.
OLLAMA_MODEL=gemma4:4b

# ---- Crew Configuration ----
# Directory containing crew YAML definitions.
CREWS_DIR=crews

# ---- Code Execution (SECURITY-SENSITIVE) ----
# When true, agents with can_execute=true in their YAML definition
# can run whitelisted system commands (netstat, ps, tasklist, etc.)
# on the host machine.  Only read-only inspection commands are
# permitted — see the hardcoded whitelist in core_orchestrator.py.
#
# WARNING: Enable this only on machines you control.  The command
# whitelist is strict, but you accept residual risk of information
# disclosure from local system inspection.
ENABLE_CODE_EXECUTION=false

# Maximum seconds a single command may run before being killed.
COMMAND_TIMEOUT=30

# ---- Logging ----
# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---- Dashboard ----
# Local web dashboard for real-time monitoring.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8585

# ---- Multi-Provider LLM (Optional Cloud Backends) ----
# By default, NanoCrew-Local uses Ollama (free, local, private).
# To unlock cloud LLMs, set API keys below.

# Default LLM provider: ollama | claude | openai
DEFAULT_PROVIDER=ollama

# Anthropic Claude API (https://console.anthropic.com/)
# Enables model syntax: claude:claude-sonnet-4-20250514
ANTHROPIC_API_KEY=

# OpenAI-compatible API (OpenAI, Groq, Together, local vLLM, etc.)
# Enables model syntax: openai:gpt-4o, openai:llama-3-70b, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Coding Agent (SECURITY-SENSITIVE) ----
# When true, agents with can_code=true in their YAML definition
# can write and execute Python/JavaScript code in a sandbox.
# The code runs with a timeout and in a temp directory, but it
# CAN access the network and local filesystem within that dir.
#
# WARNING: Only enable on machines you control.
ENABLE_CODE_AGENT=false

# Max iterations for the code-write-execute-fix loop.
CODE_AGENT_MAX_ITERATIONS=5

# Seconds before a code execution is killed.
CODE_AGENT_TIMEOUT=60

# ---- OpenClaw Integration (Optional) ----
# Bidirectional bridge to OpenClaw (https://github.com/openclaw/openclaw).
#
# When enabled, NanoCrew-Local:
#   1. Connects to the OpenClaw Gateway WebSocket as a skill provider
#   2. Accepts tasks from OpenClaw and routes them through crew pipelines
#   3. Can send messages back into OpenClaw sessions
#
# Also exposes REST API at POST /api/crew/run for direct HTTP access.
ENABLE_OPENCLAW=false

# OpenClaw Gateway WebSocket URL (default: localhost).
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Auth token for OpenClaw Gateway (from openclaw config or onboarding).
OPENCLAW_API_TOKEN=

# Default crew to use when OpenClaw doesn't specify one.
# Leave empty to use the first loaded crew.
OPENCLAW_DEFAULT_CREW=
