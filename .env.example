# ============================================================
# NanoCrew-Local — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---- Telegram Bot ----
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Comma-separated Telegram usernames authorized to use this bot.
# Do NOT include the @ symbol.  Example: alice,bob,charlie
ALLOWED_USERNAMES=your_username_here

# ---- Ollama (Local LLM) ----
# Base URL of your running Ollama instance.
OLLAMA_BASE_URL=http://localhost:11434

# Default model for all agents. Override per-agent in crew YAML files.
OLLAMA_MODEL=gemma4:4b

# ---- Crew Configuration ----
# Directory containing crew YAML definitions.
CREWS_DIR=crews

# ---- Code Execution (SECURITY-SENSITIVE) ----
# When true, agents with can_execute=true in their YAML definition
# can run whitelisted system commands (netstat, ps, tasklist, etc.)
# on the host machine.  Only read-only inspection commands are
# permitted — see the hardcoded whitelist in core_orchestrator.py.
#
# WARNING: Enable this only on machines you control.  The command
# whitelist is strict, but you accept residual risk of information
# disclosure from local system inspection.
ENABLE_CODE_EXECUTION=false

# Maximum seconds a single command may run before being killed.
COMMAND_TIMEOUT=30

# ---- Logging ----
# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
